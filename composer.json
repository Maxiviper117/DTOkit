{
    "name": "maxiviper117/dtokit-core",
    "description": "Framework-agnostic typed data boundaries for PHP",
    "keywords": [
        "php",
        "dto",
        "data",
        "mapping",
        "serialization"
    ],
    "homepage": "https://github.com/Maxiviper117/DTOkit",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxiviper117",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "pestphp/pest": "^4.7",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "DTOKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DTOKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "test": "pest",
        "test-coverage": "pest --coverage --min=100",
        "format": "pint",
        "format-test": "pint --test",
        "refactor": "rector process",
        "refactor-test": "rector process --dry-run",
        "check": [
            "@format-test",
            "@analyse",
            "@refactor-test",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
